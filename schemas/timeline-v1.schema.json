{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/timeline-v1.schema.json",
  "title": "aio:timeline@1",
  "description": "Structural shape for aio:timeline@1. The CLI at scripts/aio.mjs is the source of truth for invariants. Items render in source order — no sorting.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "asOf":  { "type": "string", "maxLength": 40,  "pattern": "^[^<>]*$" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "time":  { "type": "string", "maxLength": 60,  "pattern": "^[^<>]*$" },
          "title": { "type": "string", "maxLength": 120, "pattern": "^[^<>]*$" },
          "body":  { "type": "string", "maxLength": 400, "pattern": "^[^<>]*$" },
          "tone":  { "type": "string", "enum": ["info", "good", "warn", "bad", "neutral"] }
        },
        "required": ["time", "title"]
      }
    }
  },
  "required": ["items"]
}
