{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/metric-cards-v1.schema.json",
  "title": "aio:metric-cards@1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "maxLength": 80, "pattern": "^[^<>]*$" },
          "value": { "type": "string", "maxLength": 40, "pattern": "^[^<>]*$" },
          "note": { "type": "string", "maxLength": 120, "pattern": "^[^<>]*$" },
          "tone": { "type": "string", "enum": ["neutral", "good", "warn", "bad"] }
        },
        "required": ["label", "value"]
      }
    }
  },
  "required": ["items"]
}

