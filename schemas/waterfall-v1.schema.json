{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/waterfall-v1.schema.json",
  "title": "aio:waterfall@1",
  "description": "Structural shape for aio:waterfall@1. The CLI at scripts/aio.mjs is the source of truth for invariants — notably that bars[0].kind must be 'start'.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title":    { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "subtitle": { "type": "string", "maxLength": 160, "pattern": "^[^<>]*$" },
    "asOf":     { "type": "string", "maxLength": 40,  "pattern": "^[^<>]*$" },
    "format":   { "type": "string", "pattern": "^(?:raw|number|percent|compact|currency:[A-Z]{3})$" },
    "bars": {
      "type": "array",
      "minItems": 2,
      "maxItems": 14,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "maxLength": 60, "pattern": "^[^<>]*$" },
          "value": { "type": "number" },
          "kind":  { "type": "string", "enum": ["start", "up", "down", "subtotal", "end"] },
          "note":  { "type": "string", "maxLength": 140, "pattern": "^[^<>]*$" }
        },
        "required": ["label", "value", "kind"]
      }
    }
  },
  "required": ["bars"]
}
