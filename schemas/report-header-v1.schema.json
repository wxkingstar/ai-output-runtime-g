{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/report-header-v1.schema.json",
  "title": "aio:report-header@1",
  "description": "Structural shape for aio:report-header@1. The CLI at scripts/aio.mjs is the source of truth for invariants. Frontmatter shortcut is documented in the spec.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title":          { "type": "string", "maxLength": 140, "pattern": "^[^<>]*$" },
    "subtitle":       { "type": "string", "maxLength": 200, "pattern": "^[^<>]*$" },
    "period":         { "type": "string", "maxLength": 60,  "pattern": "^[^<>]*$" },
    "author":         { "type": "string", "maxLength": 80,  "pattern": "^[^<>]*$" },
    "status":         { "type": "string", "enum": ["draft", "review", "final", "archived"] },
    "dataAsOf":       { "type": "string", "maxLength": 40,  "pattern": "^[^<>]*$" },
    "classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
    "badges": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "maxLength": 40, "pattern": "^[^<>]*$" },
          "tone":  { "type": "string", "enum": ["info", "good", "warn", "bad", "neutral"] }
        },
        "required": ["label"]
      }
    }
  },
  "required": ["title"]
}
