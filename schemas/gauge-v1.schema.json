{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/gauge-v1.schema.json",
  "title": "aio:gauge@1",
  "description": "Structural shape for aio:gauge@1. The CLI at scripts/aio.mjs is the source of truth for invariants — notably max > min.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "asOf":  { "type": "string", "maxLength": 40,  "pattern": "^[^<>]*$" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label":  { "type": "string", "maxLength": 80, "pattern": "^[^<>]*$" },
          "value":  { "type": "number" },
          "min":    { "type": "number" },
          "max":    { "type": "number" },
          "target": { "type": "number" },
          "format": { "type": "string", "pattern": "^(?:raw|number|percent|compact|currency:[A-Z]{3})$" },
          "tone":   { "type": "string", "enum": ["neutral", "good", "warn", "bad"] },
          "note":   { "type": "string", "maxLength": 140, "pattern": "^[^<>]*$" }
        },
        "required": ["label", "value"]
      }
    }
  },
  "required": ["items"]
}
