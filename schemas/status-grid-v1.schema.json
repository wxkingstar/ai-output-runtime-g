{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-output.dev/schemas/status-grid-v1.schema.json",
  "title": "aio:status-grid@1",
  "description": "Structural shape for aio:status-grid@1. The CLI at scripts/aio.mjs is the source of truth for invariants.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "maxLength": 100, "pattern": "^[^<>]*$" },
    "asOf":  { "type": "string", "maxLength": 40,  "pattern": "^[^<>]*$" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "label":  { "type": "string", "maxLength": 80, "pattern": "^[^<>]*$" },
          "status": { "type": "string", "enum": ["good", "warn", "bad", "neutral", "info"] },
          "value":  { "type": "string", "maxLength": 60, "pattern": "^[^<>]*$" },
          "note":   { "type": "string", "maxLength": 140, "pattern": "^[^<>]*$" }
        },
        "required": ["label", "status"]
      }
    }
  },
  "required": ["items"]
}
